-- ===== CẤU HÌNH =====
local AIM_RANGE = 100                 -- Khoảng cách tối đa để tìm mục tiêu (studs)
local STRONG_MOVE_THRESHOLD = 0.25    -- Góc lệch tối đa (radian) trước khi hủy aim (~14 độ)
local CHECK_OBSTACLE = true           -- Bật/tắt kiểm tra vật cản

-- ===== TRẠNG THÁI =====
