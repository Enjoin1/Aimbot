    currentTarget = nil
    targetPosition = nil
    if aimEnabled then
        aimActive = false
        startAimLoop()
    end
end)

player:GetPropertyChangedSignal("Character"):Connect(function()
    if not player.Character then
        stopAimLoop()
    end
end)

