local function UpdateESP()
    for _, obj in pairs(ESPCache) do
        if obj and obj.Frame then obj.Frame:Destroy() end
    end
    ESPCache = {}
    if not Settings.ESP then return end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not Settings.ShowTeammates and IsTeammate(plr) then continue end
        local char = plr.Character
        if not IsAlive(char) then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then continue end

        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0,200,0,60)
        frame.Position = UDim2.new(0, screenPos.X-100, 0, screenPos.Y-30)
        frame.BackgroundTransparency = 0.5
        frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
        frame.BorderSizePixel = 0
        frame.Parent = ScreenGui
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0,4)
        corner.Parent = frame

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1,0,0,20)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = plr.Name
        if Settings.ESPTeam and IsTeammate(plr) then
            nameLabel.TextColor3 = Color3.fromRGB(0,255,0)
        else
            nameLabel.TextColor3 = Color3.fromRGB(255,0,0)
        end
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextXAlignment = Enum.TextXAlignment.Center
        nameLabel.Visible = Settings.ESPName
        nameLabel.Parent = frame

        local healthLabel = Instance.new("TextLabel")
        healthLabel.Size = UDim2.new(1,0,0,18)
        healthLabel.Position = UDim2.new(0,0,0,20)
        healthLabel.BackgroundTransparency = 1
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        healthLabel.Text = "HP: " .. (humanoid and math.floor(humanoid.Health) or "?")
        healthLabel.TextColor3 = Color3.fromRGB(255,255,255)
        healthLabel.TextSize = 12
        healthLabel.Font = Enum.Font.Gotham
        healthLabel.TextXAlignment = Enum.TextXAlignment.Center
        healthLabel.Visible = Settings.ESPHealth
        healthLabel.Parent = frame

        local distLabel = Instance.new("TextLabel")
        distLabel.Size = UDim2.new(1,0,0,18)
        distLabel.Position = UDim2.new(0,0,0,38)
        distLabel.BackgroundTransparency = 1
        local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
        distLabel.Text = string.format("%.1f m", dist)
        distLabel.TextColor3 = Color3.fromRGB(200,200,200)
        distLabel.TextSize = 12
        distLabel.Font = Enum.Font.Gotham
        distLabel.TextXAlignment = Enum.TextXAlignment.Center
        distLabel.Visible = Settings.ESPDistance
        distLabel.Parent = frame

        ESPCache[plr] = {
            Frame = frame,
            Name = nameLabel,
            Health = healthLabel,
            Distance = distLabel,
        }
    end
end

RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = Settings.FOVCircle
    FOVGlow.Visible = Settings.FOVCircle
    FOVLabel.Visible = Settings.FOVCircle
    FOVLabel.Text = tostring(Settings.FOVRadius)

    if Settings.NoRecoil then NoRecoil() end
    if Settings.InfiniteAmmo then InfiniteAmmo() end
    if Settings.Triggerbot then Triggerbot() end

    if Settings.Aimlock then
        local target = GetTargets()
        if target then
            local targetPos = target.Part + GetRandomOffset()
            local camPos = Camera.CFrame.Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(camPos, targetPos), Settings.AimSmoothness)
        end
    end

    if Settings.ESP then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if not Settings.ShowTeammates and IsTeammate(plr) then continue end
            local char = plr.Character
            if not IsAlive(char) then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local obj = ESPCache[plr]
            if obj and onScreen then
                obj.Frame.Position = UDim2.new(0, screenPos.X-100, 0, screenPos.Y-30)
                obj.Frame.Visible = true
                if Settings.ESPName then
                    obj.Name.Visible = true
                    obj.Name.TextColor3 = (Settings.ESPTeam and IsTeammate(plr)) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                else
                    obj.Name.Visible = false
                end
                if Settings.ESPHealth then
                    obj.Health.Visible = true
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    obj.Health.Text = "HP: " .. (humanoid and math.floor(humanoid.Health) or "?")
                else
                    obj.Health.Visible = false
                end
                if Settings.ESPDistance then
                    obj.Distance.Visible = true
                    local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
                    obj.Distance.Text = string.format("%.1f m", dist)
                else
                    obj.Distance.Visible = false
                end
            elseif obj then
                obj.Frame.Visible = false
            end
        end
    else
        for _, obj in pairs(ESPCache) do
            if obj and obj.Frame then obj.Frame.Visible = false end
        end
    end
end)

