-- ===== KÉO THẢ MENU (SỬA LỖI) =====
local function makeDraggable(frame, handle)
    local dragging = false
    local dragStart = nil
    local startPos = nil

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            -- Cập nhật vị trí dạng UDim2 (giữ nguyên tỉ lệ, cộng offset)
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

makeDraggable(mainFrame, titleBar)

-- ===== CẬP NHẬT UI =====
local function updateUI()
    if aimEnabled then
        toggleBtn.Text = "On"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    else
        toggleBtn.Text = "Off"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
end

-- ===== TÌM MỤC TIÊU =====
local function findTarget()
    local character = player.Character
    if not character or not character:FindFirstChild("Head") then return nil end
    local headPos = character.Head.Position

    local bestTarget = nil
    local bestDist = math.huge

    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("Head") and otherChar:FindFirstChild("Humanoid") then
                local humanoid = otherChar.Humanoid
                if humanoid.Health > 0 then
                    local otherHeadPos = otherChar.Head.Position
                    local dist = (otherHeadPos - headPos).Magnitude
                    if dist < bestDist and dist <= AIM_RANGE then
                        bestDist = dist
                        bestTarget = otherChar
                    end
                end
            end
        end
    end
    return bestTarget
end

-- ===== KIỂM TRA VẬT CẢN =====
local function hasObstacle(origin, targetPos)
    if not CHECK_OBSTACLE then return false end
    local direction = (targetPos - origin).Unit
    local distance = (targetPos - origin).Magnitude
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {player.Character, currentTarget}
    local result = Workspace:Raycast(origin, direction * distance, params)
    return result ~= nil
end

-- ===== HÀM HỦY AIM DO KÉO MẠNH =====
local function cancelAim()
    if aimEnabled and aimActive then
        aimActive = false
        currentTarget = nil
        targetPosition = nil
        aimEnabled = false
        updateUI()
        print("Aimlock disabled: strong camera move.")
    end
end

-- ===== VÒNG LẶP AIM (MỖI FRAME) =====
local function updateAim()
    if not aimEnabled then
        aimActive = false
        currentTarget = nil
        return
    end

    -- 1. Tìm hoặc làm mới mục tiêu
    if not currentTarget or not currentTarget.Parent then
        currentTarget = findTarget()
        if not currentTarget then
            aimActive = false
            return
        end
        targetPosition = currentTarget.Head.Position
    else
        targetPosition = currentTarget.Head.Position
    end

    local camPos = camera.CFrame.Position

    -- 2. Kiểm tra vật cản
    if hasObstacle(camPos, targetPosition) then
        isObstructed = true
        aimActive = false   -- Tạm dừng aim
        return
    else
        isObstructed = false
    end

    -- 3. Kiểm tra kéo mạnh
    local currentLook = camera.CFrame.LookVector
    local desiredLook = (targetPosition - camPos).Unit
    local dot = currentLook:Dot(desiredLook)
    local angle = math.acos(math.clamp(dot, -1, 1))
    if angle > STRONG_MOVE_THRESHOLD then
        cancelAim()
        return
    end

    -- 4. Ghim camera vào đầu mục tiêu
    aimActive = true
    camera.CFrame = CFrame.new(camPos, targetPosition)
end

-- ===== QUẢN LÝ VÒNG LẶP =====
local function startLoop()
    if loopConnection then loopConnection:Disconnect() end
    loopConnection = RunService.RenderStepped:Connect(updateAim)
end

local function stopLoop()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    aimActive = false
    currentTarget = nil
end

-- ===== SỰ KIỆN NÚT =====
toggleBtn.MouseButton1Click:Connect(function()
    aimEnabled = not aimEnabled
    if aimEnabled then
        startLoop()
    else
        stopLoop()
    end
    updateUI()
end)

hideBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
    if not showButton then
        showButton = Instance.new("TextButton")
        showButton.Size = UDim2.new(0, 50, 0, 50)
        showButton.Position = UDim2.new(0, 10, 0, 10)
        showButton.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        showButton.Text = "Aim"
        showButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        showButton.TextScaled = true
        showButton.Font = Enum.Font.SourceSans
        showButton.Parent = screenGui
        showButton.MouseButton1Click:Connect(function()
            mainFrame.Visible = true
            showButton.Visible = false
        end)
    else
        showButton.Visible = true
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    stopLoop()
    screenGui:Destroy()
end)

-- ===== XỬ LÝ RESPAWN =====
player.CharacterAdded:Connect(function()
    currentTarget = nil
    targetPosition = nil
    if aimEnabled then
        aimActive = false
        startLoop()
    end
end)

player:GetPropertyChangedSignal("Character"):Connect(function()
    if not player.Character then
        stopLoop()
    end
end)

-- Khởi tạo
updateUI()

