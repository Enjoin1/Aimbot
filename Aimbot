-- ===== HÀM HỖ TRỢ DI CHUYỂN MENU =====
local function makeDraggable(frame, handle)
    local dragging = false
    local dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    handle.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

makeDraggable(mainFrame, titleBar)

-- ===== CẬP NHẬT GIAO DIỆN =====
local function updateUI()
    if aimEnabled then
        toggleBtn.Text = "On"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    else
        toggleBtn.Text = "Off"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
end

-- ===== TÌM MỤC TIÊU (người chơi gần nhất, còn sống) =====
local function findTarget()
    local character = player.Character
    if not character or not character:FindFirstChild("Head") then return nil end
    local headPos = character.Head.Position

    local bestTarget = nil
    local bestDist = math.huge

    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("Head") and otherChar:FindFirstChild("Humanoid") then
                local humanoid = otherChar.Humanoid
                if humanoid.Health > 0 then
                    local otherHeadPos = otherChar.Head.Position
                    local dist = (otherHeadPos - headPos).Magnitude
                    if dist < bestDist and dist <= AIM_RANGE then
                        bestDist = dist
                        bestTarget = otherChar
                    end
                end
            end
        end
    end
    return bestTarget
end

-- ===== KIỂM TRA VẬT CẢN =====
local function isObstructedBetween(pos1, pos2)
    if not CHECK_OBSTACLE then return false end
    local direction = (pos2 - pos1).Unit
    local distance = (pos2 - pos1).Magnitude
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {player.Character, currentTarget}
    local result = Workspace:Raycast(pos1, direction * distance, params)
    return result ~= nil
end

-- ===== HỦY AIM DO KÉO MẠNH =====
local function cancelAimDueToStrongMove()
    if aimEnabled and aimActive then
        aimActive = false
        currentTarget = nil
        targetPosition = nil
        aimEnabled = false   -- Tắt hẳn, người dùng phải bật lại qua menu
        updateUI()
        print("Aimlock disabled due to strong camera movement.")
    end
end

-- ===== VÒNG LẶP AIM =====
local function updateAim()
    if not aimEnabled then
        aimActive = false
        currentTarget = nil
        return
    end

    -- 1. Tìm hoặc làm mới mục tiêu
    if not currentTarget or not currentTarget.Parent then
        currentTarget = findTarget()
        if not currentTarget then
            aimActive = false
            return
        end
        targetPosition = currentTarget.Head.Position
    else
        targetPosition = currentTarget.Head.Position
    end

    -- Vị trí camera hiện tại
    local camPos = camera.CFrame.Position

    -- 2. Kiểm tra vật cản (từ mắt camera đến mục tiêu)
    if isObstructedBetween(camPos, targetPosition) then
        isObstructed = true
        aimActive = false   -- Tạm ngưng aim
        return
    else
        isObstructed = false
    end

    -- 3. Kiểm tra kéo mạnh (so sánh hướng hiện tại và hướng mong muốn)
    local currentLook = camera.CFrame.LookVector
    local desiredLook = (targetPosition - camPos).Unit
    local dot = currentLook:Dot(desiredLook)
    local angle = math.acos(math.clamp(dot, -1, 1))
    if angle > STRONG_MOVE_THRESHOLD then
        cancelAimDueToStrongMove()
        return
    end

    -- 4. Nếu mọi điều kiện tốt → ghim camera vào đầu mục tiêu
    aimActive = true
    local newCF = CFrame.new(camPos, targetPosition)
    camera.CFrame = newCF
end

-- ===== QUẢN LÝ VÒNG LẶP =====
local loopConnection = nil

local function startAimLoop()
    if loopConnection then loopConnection:Disconnect() end
    loopConnection = RunService.RenderStepped:Connect(updateAim)
end

local function stopAimLoop()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    aimActive = false
    currentTarget = nil
end

-- ===== SỰ KIỆN NÚT MENU =====
